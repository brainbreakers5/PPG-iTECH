# Server encryption key (base64 of 32 bytes). Example generation:
#   node -e "console.log(Buffer.from(require('crypto').randomBytes(32)).toString('base64'))"
API_ENC_KEY=

# Optional HTTPS certs: set either paths or raw PEM
# HTTPS_KEY_PATH=C:\path\to\privkey.pem
# HTTPS_CERT_PATH=C:\path\to\cert.pem
# or (not recommended) set raw PEM strings:
# HTTPS_KEY="-----BEGIN PRIVATE KEY-----..."
# HTTPS_CERT="-----BEGIN CERTIFICATE-----..."

# Client-side (Vite) build-time env: base64 32-byte key
# Use same key as API_ENC_KEY but prefixed with VITE_ so it is injected at build time
# Example: VITE_API_ENC_KEY=<same base64 value as API_ENC_KEY>
VITE_API_ENC_KEY=
