PORT=5000
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=ppg_emp_hub_db
DB_PORT=5432

JWT_SECRET=your_jwt_secret_key_change_me
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# API Encryption (AES-256-GCM)
# Generate a 32-byte key: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
API_ENC_KEY=your_base64_32byte_key
ALLOW_PLAINTEXT_FALLBACK=0

# HTTPS (Optional for local, required for production)
# HTTPS_KEY_PATH=./ssl/privkey.pem
# HTTPS_CERT_PATH=./ssl/fullchain.pem

# Email Configuration
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
